FROM node:16

# Создаем рабочую директорию внутри образа
WORKDIR /usr/src/app

# Сначала копируем только файлы зависимостей (для кэширования)
COPY package*.json ./

# Устанавливаем зависимости
RUN npm install

# Копируем остальные файлы проекта
COPY . .

# Запускаем приложение
CMD ["node", "index.js"]
